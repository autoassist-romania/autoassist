{
  "functions": {
    "api/*.js": {
      "runtime": "edge"
    }
  },
  "crons": [
    {
      "path": "/api/ping-supabase",
      "schedule": "0 10 * * *"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, OPTIONS" }
      ]
    }
  ]
}
